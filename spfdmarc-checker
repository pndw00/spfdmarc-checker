#!/usr/bin/env bash

VERSION='2.3'

# ANSI Style
RED='\033[31m'
GREEN='\033[32m'
YELLOW='\033[33m'
BLUE='\033[34m'
CYAN='\033[36m'
BOLD='\033[1m'
RESET='\033[0m' # RESET

# Separator
SEP="-----------------------------------"

show_header=true

# Disable ANSI colors (--no-color or non-TTY output)
disable_colors() {
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' RESET=''
}

# Decide on colors before any output, so --help and error messages are
# also stripped when needed (non-TTY, NO_COLOR env, or --no-color flag).
if [[ -n "$NO_COLOR" ]] || [[ ! -t 1 ]]; then
    disable_colors
fi
for arg in "$@"; do
    [[ "$arg" == "--no-color" ]] && { disable_colors; break; }
done

show_help() {
    local script_name
    script_name=$(basename "$0")

    echo -e "${BOLD}${BLUE}Usage:${RESET} ${GREEN}$script_name [options] domain.com${RESET}"
    echo
    echo -e "${BOLD}${BLUE}Options:${RESET}"
    echo -e "  ${YELLOW}-h, --help${RESET}           Show this help message"
    echo -e "  ${YELLOW}--mx${RESET}                 [✓] Only analyze MX record"
    echo -e "  ${YELLOW}--spf${RESET}                [✓] Only analyze SPF record"
    echo -e "  ${YELLOW}--dmarc${RESET}              [✓] Only analyze DMARC record"
    echo -e "  ${YELLOW}--dkim${RESET}               [✓] Only analyze DKIM record"
    echo -e "  ${YELLOW}-s, --selector SEL${RESET}   Test a specific DKIM selector"
    echo -e "  ${YELLOW}--dns 8.8.8.8${RESET}        Perform DNS resolutions with custom DNS server (default: system resolver)"
    echo -e "  ${YELLOW}-q, --quiet${RESET}          Hide header"
    echo -e "  ${YELLOW}--no-color${RESET}           Disable colored output (auto-detected if not a TTY)"
    echo
    echo -e "${BOLD}${BLUE}Description:${RESET}"
    echo -e "  This script retrieves and analyzes ${CYAN}MX${RESET}, ${CYAN}SPF${RESET}, ${CYAN}DMARC${RESET} and ${CYAN}DKIM${RESET} records for the given domain."
    echo -e "  It helps auditing email security quickly and visually."
    echo
    echo -e "${BOLD}${BLUE}Example:${RESET}"
    echo -e "  ${GREEN}$script_name example.com${RESET}                     # Analyze all records"
    echo -e "  ${GREEN}$script_name --mx example.com${RESET}                # Analyze only MX"
    echo -e "  ${GREEN}$script_name --spf example.com${RESET}               # Analyze only SPF"
    echo -e "  ${GREEN}$script_name --dmarc example.com${RESET}             # Analyze only DMARC"
    echo -e "  ${GREEN}$script_name --dkim example.com${RESET}              # Analyze only DKIM"
    echo -e "  ${GREEN}$script_name --dkim -s default example.com${RESET}   # Analyze DKIM for a specific selector"
    echo
    echo -e "${BOLD}${BLUE}Symbols:${RESET}"
    echo -e "  [${BOLD}${GREEN}✓${RESET}] Success / Found"
    echo -e "  [${BOLD}${YELLOW}!!${RESET}] Warning / Partial"
    echo -e "  [${BOLD}${RED}✗${RESET}] Error / Missing / Dangerous"
}

# Recursive SPF DNS lookup counter (RFC 7208: max 10)
# Counts: include, a, mx, ptr, exists, redirect (each = 1 lookup)
# Then follows include/redirect recursively
_spf_lookup_total=0
_spf_resolved=()
_spf_permerror=0

count_spf_lookups() {
    local domain="$1"; shift
    local path=("$@")

    local p
    for p in "${path[@]}"; do
        [[ "$p" == "$domain" ]] && { _spf_permerror=1; return; }   # cycle -> PermError
    done
    case " ${_spf_resolved[*]} " in *" $domain "*) return ;; esac   # already expanded -> skip subtree

    local record
    record=$(dig +short TXT "$domain" ${DNS_SERVER:+"$DNS_SERVER"} 2>/dev/null \
             | grep 'v=spf1' | head -n1 | sed 's/" "//g' | tr -d '"')
    [[ -z "$record" ]] && return

    _spf_resolved+=("$domain")
    path+=("$domain")

    # 'redirect' is ignored when an 'all' mechanism is present.
    local has_all=0
    [[ "$record" =~ (^|[[:space:]])[-~?+]?all([[:space:]]|$) ]] && has_all=1

    local -a tokens; read -ra tokens <<< "$record"
    local tok mech
    for tok in "${tokens[@]}"; do
        mech="${tok#[-~?+]}"   # strip an optional qualifier (+ - ~ ?)
        case "$mech" in
            include:*)
                (( _spf_lookup_total++ ))
                count_spf_lookups "${mech#include:}" "${path[@]}" ;;
            redirect=*)
                (( has_all )) && continue
                (( _spf_lookup_total++ ))
                count_spf_lookups "${mech#redirect=}" "${path[@]}" ;;
            a|a:*|a/*|mx|mx:*|mx/*|ptr|ptr:*|exists:*)
                (( _spf_lookup_total++ )) ;;
        esac
    done
}

# Classify a TXT lookup (RFC 7208 §4.4): returns success (0) only on a transient
# DNS failure – SERVFAIL/REFUSED or a timeout/unreachable server – which maps to
# "temperror". NXDOMAIN and NOERROR mean the lookup completed (no record / record
# present), so they are NOT temperrors.
dns_txt_temperror() {
    local name="$1" out status rc
    out=$(dig +noall +comments TXT "$name" ${DNS_SERVER:+"$DNS_SERVER"} 2>/dev/null)
    rc=$?
    (( rc != 0 )) && return 0          # timeout / no server reached
    status=$(sed -n 's/.*status: \([A-Z]*\).*/\1/p' <<< "$out" | head -n1)
    case "$status" in
        NOERROR|NXDOMAIN) return 1 ;;   # completed: none or record, not a temperror
        *)                return 0 ;;   # SERVFAIL/REFUSED/unknown -> temperror
    esac
}

dmarc_check_external_destinations() {
    local policy_domain="$1" label="$2"; shift 2
    local uri host lp lh authname seen=""
    lp=$(printf '%s' "$policy_domain" | tr '[:upper:]' '[:lower:]')
    for uri in "$@"; do
        uri=$(printf '%s' "$uri" | tr -d '[:space:]')   # DMARC URIs carry no spaces
        [[ -z "$uri" ]] && continue
        # Extract the destination host: mailto:user@host or scheme://host[/path]
        host="${uri%%\!*}"      # drop the obsolete "!size" suffix
        host="${host##*@}"      # mailto:user@host  -> host
        host="${host##*://}"    # scheme://host/... -> host/...
        host="${host%%/*}"      # strip any path
        host="${host%%:*}"      # strip any port
        host="${host%.}"        # strip a trailing dot
        [[ -z "$host" ]] && continue
        lh=$(printf '%s' "$host" | tr '[:upper:]' '[:lower:]')
        case " $seen " in *" $lh "*) continue ;; esac   # de-duplicate per tag
        seen="$seen $lh"
        # Same organization (identical, sub- or parent domain) needs no authorization
        if [[ "$lh" == "$lp" || "$lh" == *".$lp" || "$lp" == *".$lh" ]]; then
            continue
        fi
        authname="${policy_domain}._report._dmarc.${host}"
        if dig +short TXT "$authname" ${DNS_SERVER:+"$DNS_SERVER"} 2>/dev/null | grep -qE 'v=DMARC1[; "]'; then
            echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}$label external destination $host is authorized ($authname)${RESET}"
        else
            echo -e "[${BOLD}${RED}✗${RESET}] ${RED}$label external destination $host NOT authorized – $authname has no v=DMARC1; reports will not be sent (RFC 9990)${RESET}"
        fi
    done
}

analyze_mx() {
    local domain="$1"

    echo -e "${BOLD}$SEP${RESET}"
    echo -e "${BOLD}${BLUE}MX Record Check:${RESET}"
    echo -e "${BOLD}$SEP${RESET}"

    # Get MX
    mx_records=$(dig +short MX "$domain" ${DNS_SERVER:+"$DNS_SERVER"})
    if [[ -z "$mx_records" ]]; then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}No MX records found for $domain${RESET}"
        echo -e "${BOLD}$SEP${RESET}"
        return
    fi

    echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}MX records found:${RESET}"
    echo "$mx_records"
    echo

    # IPs resolution for each MX
    echo -e "${BLUE}Resolved IPs for MX servers:${RESET}"
    while read -r priority mx_host; do
        # Remove period at the end
        mx_host="${mx_host%.}"

        # Get A and AAAA and transform
        ips=$((dig +short A "$mx_host" ${DNS_SERVER:+"$DNS_SERVER"}; dig +short AAAA "$mx_host" ${DNS_SERVER:+"$DNS_SERVER"}) | sed '/^$/d')

        if [[ -z "$ips" ]]; then
            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}$mx_host has no resolved IPs${RESET}"
        else
            echo -e "[${BOLD}${GREEN}i${RESET}] ${GREEN}$mx_host :${RESET}"
            while read -r ip; do
                echo -e "  - ${GREEN}${ip}${RESET}"
            done <<< "$ips"
        fi
    done <<< "$mx_records"
}

analyze_spf() {
    local domain="$1"

    # Retrieve SPF record(s). RFC 7208 §4.5: the version section must be exactly
    # "v=spf1" terminated by a space or end of record.
    spf_all=$(dig +short TXT "$domain" ${DNS_SERVER:+"$DNS_SERVER"} | grep -E 'v=spf1[ "]' | sed 's/" "//g' | tr -d '"')
    spf_count=$(echo "$spf_all" | grep -cE 'v=spf1( |$)')

    # Use first record for analysis
    spf=$(echo "$spf_all" | head -n1)

    echo -e "${BOLD}$SEP${RESET}"
    echo -e "${BOLD}${BLUE}SPF Analysis:${RESET}"
    echo -e "${CYAN}$spf${RESET}"
    echo -e "${BOLD}$SEP${RESET}"

    # Check SPF prefix (must be "v=spf1" followed by a space or end of record)
    if [[ ! "$spf" =~ ^v=spf1($|[[:space:]]) ]]; then
        if dns_txt_temperror "$domain"; then
            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}Temporary DNS error resolving SPF (temperror) – result inconclusive${RESET}"
        else
            echo -e "[${BOLD}${RED}✗${RESET}] ${RED}SPF record not found${RESET}"
        fi
        echo -e "${BOLD}$SEP${RESET}"
        return
    fi
    echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}SPF version detected: v=spf1${RESET}"

    # Check for multiple SPF records (RFC 7208: MUST have at most one)
    if (( spf_count > 1 )); then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}Multiple SPF records found ($spf_count) – invalid per RFC 7208 (causes PermError)${RESET}"
        echo -e "${YELLOW}Records found:${RESET}"
        while IFS= read -r line; do
            echo -e "  - ${CYAN}$line${RESET}"
        done <<< "$spf_all"
    fi

    last_all=""
    redirect_target=""
    redirect_count=0
    read -ra _spf_tokens <<< "$spf"
    for mech in "${_spf_tokens[@]}"; do
        case "$mech" in
            all)        last_all="+all" ;;   # bare 'all' = implicit '+' qualifier
            [-~?+]all)  last_all="$mech" ;;
            redirect=*) redirect_target="${mech#redirect=}"; (( redirect_count++ )) ;;
        esac
    done
    if [[ -n "$last_all" ]]; then
        case "$last_all" in
            "-all")  echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}-all: Strict policy – only authorized servers may send emails${RESET}" ;;
            "~all")  echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}~all: Soft fail – unauthorized sources flagged but still accepted${RESET}" ;;
            "?all")  echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}?all: Neutral – no effective SPF protection${RESET}" ;;
            "+all")  echo -e "[${BOLD}${RED}✗${RESET}] ${RED}+all: Permits ANY sender – highly dangerous configuration${RESET}" ;;
        esac
        # RFC 7208: a 'redirect' modifier is ignored when an 'all' mechanism is present
        if [[ -n "$redirect_target" ]]; then
            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}redirect=$redirect_target present but IGNORED – 'all' takes precedence (RFC 7208)${RESET}"
        fi
    elif [[ -n "$redirect_target" ]]; then
        # RFC 7208 §4.7: with no 'all', the 'redirect' provides the record's result
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}No 'all' mechanism – processing is redirected to $redirect_target (RFC 7208)${RESET}"
        # The redirect target must publish an SPF record, else PermError (RFC 7208 §6.1)
        if [[ "$redirect_target" != *%* ]]; then
            if dig +short TXT "$redirect_target" ${DNS_SERVER:+"$DNS_SERVER"} 2>/dev/null | grep -q 'v=spf1'; then
                echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}redirect target $redirect_target publishes an SPF record${RESET}"
            else
                echo -e "[${BOLD}${RED}✗${RESET}] ${RED}redirect target $redirect_target has NO SPF record – PermError (RFC 7208)${RESET}"
            fi
        fi
    else
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}No 'all' mechanism and no redirect – falls through to implicit ?all (neutral, no protection)${RESET}"
    fi

    # RFC 7208 §6: the 'redirect' modifier MUST NOT appear more than once
    if (( redirect_count > 1 )); then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}Multiple redirect modifiers ($redirect_count) – invalid per RFC 7208 (causes PermError)${RESET}"
    fi

    echo
    # DNS lookup count – recursive (RFC 7208: max 10 total, includes nested)
    _spf_lookup_total=0; _spf_resolved=(); _spf_permerror=0
    count_spf_lookups "$domain"
    dns_lookup_count=$_spf_lookup_total

    if (( dns_lookup_count > 10 )); then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}DNS lookups: $dns_lookup_count/10 – exceeds RFC 7208 limit (causes PermError)${RESET}"
    elif (( dns_lookup_count >= 8 )); then
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}DNS lookups: $dns_lookup_count/10 – approaching RFC 7208 limit${RESET}"
    else
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}DNS lookups: $dns_lookup_count/10${RESET}"
    fi
    (( _spf_permerror )) && echo -e "[${BOLD}${RED}✗${RESET}] ${RED}Circular reference in SPF – PermError${RESET}"
    if (( ${#_spf_resolved[@]} > 1 )); then
        echo -e "${BLUE}Domains resolved:${RESET} ${_spf_resolved[*]}"
    fi

    echo
    echo -e "${BLUE}Detected mechanisms:${RESET}"

    # Parse mechanisms
    while read -r mech; do
        [[ -z "$mech" ]] && continue
        case "$mech" in
            include:*)   echo -e "[${BOLD}${GREEN}i${RESET}] ${GREEN}External source allowed: $mech${RESET}" ;;
            ip4:*)       echo -e "[${BOLD}${GREEN}i${RESET}] ${GREEN}Authorized IPv4: ${mech#ip4:}${RESET}" ;;
            ip6:*)       echo -e "[${BOLD}${GREEN}i${RESET}] ${GREEN}Authorized IPv6: ${mech#ip6:}${RESET}" ;;
            a|a:*|a/*)   echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}'a' mechanism detected: $mech – valid, may increase DNS lookups${RESET}" ;;
            mx|mx:*|mx/*) echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}'mx' mechanism detected: $mech – OK, but ensure all MX servers are trusted${RESET}" ;;
            ptr|ptr:*)   echo -e "[${BOLD}${RED}✗${RESET}] ${RED}'ptr' mechanism deprecated ($mech) – should be avoided${RESET}" ;;
            exists:*)    echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}Exists mechanism: ${mech#exists:} – advanced macro usage${RESET}" ;;
        esac
    done <<< "$(echo "$spf" | grep -oE '\b(ip4:[^ ]+|ip6:[^ ]+|include:[^ ]+|redirect=[^ ]+|exists:[^ ]+|a(:[^ ]+|/[^ ]+)?|mx(:[^ ]+|/[^ ]+)?|ptr(:[^ ]+)?)\b')"
}

analyze_dmarc() {
    local domain="$1"
    local policy=""

    # Retrieve DMARC record(s). The version token must be exactly "v=DMARC1"
    # terminated by ';', whitespace or end.
    dmarc_all=$(dig +short TXT "_dmarc.$domain" ${DNS_SERVER:+"$DNS_SERVER"} | grep -E 'v=DMARC1[; "]' | sed 's/" "//g' | tr -d '"')
    dmarc_count=$(echo "$dmarc_all" | grep -cE 'v=DMARC1([; ]|$)')
    dmarc=$(echo "$dmarc_all" | head -n1)

    echo -e "${BOLD}$SEP${RESET}"
    echo -e "${BOLD}${BLUE}DMARC Analysis:${RESET}"
    echo -e "${CYAN}$dmarc${RESET}"
    echo -e "${BOLD}$SEP${RESET}"

    # Check DMARC prefix (must be "v=DMARC1" followed by ';', a space or end)
    if [[ ! "$dmarc" =~ ^v=DMARC1($|[[:space:];]) ]]; then
        if dns_txt_temperror "_dmarc.$domain"; then
            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}Temporary DNS error resolving DMARC (temperror) – result inconclusive${RESET}"
        else
            echo -e "[${BOLD}${RED}✗${RESET}] ${RED}DMARC record not found${RESET}"
        fi
        echo -e "${BOLD}$SEP${RESET}"
        return
    fi

    # RFC 9989: if more than one DMARC record exists for the name, they are ALL
    # discarded (no DMARC is applied), so do not analyze any of them.
    if (( dmarc_count > 1 )); then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}Multiple DMARC records found ($dmarc_count) – all discarded per RFC 9989 (no DMARC applied)${RESET}"
        echo -e "${YELLOW}Records found:${RESET}"
        while IFS= read -r line; do
            echo -e "  - ${CYAN}$line${RESET}"
        done <<< "$dmarc_all"
        echo -e "${BOLD}$SEP${RESET}"
        return
    fi

    echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}DMARC version detected: v=DMARC1${RESET}"

    # Check DMARC Policy (p) – anchored so np=/sp= aren't matched as p=
    if [[ "$dmarc" =~ (^|[[:space:];])p=none ]]; then
        policy="none"
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}p=none: Emails that fail verification pass through${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])p=quarantine ]]; then
        policy="quarantine"
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}p=quarantine: Suspicious emails go to spam (partial protection)${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])p=reject ]]; then
        policy="reject"
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}p=reject: Non-compliant emails rejected (strong protection)${RESET}"
    else
        # RFC 9989: 'p' is RECOMMENDED, not mandatory; an absent or invalid
        # 'p' tag is treated as if the record contained p=none.
        policy="none"
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}p absent/invalid: treated as p=none => emails not protected${RESET}"
    fi

        # Check DMARC subdomains Policy (sp)
    if [[ "$dmarc" =~ (^|[[:space:];])sp=none ]]; then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}sp=none: Subdomains not protected${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])sp=quarantine ]]; then
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}sp=quarantine: Suspicious emails from subdomains go to spam${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])sp=reject ]]; then
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}sp=reject: Strong protection for subdomains${RESET}"
    else
        #sp not defined > fallback on p=
        if [[ "$policy" == "none"  ]]; then
            echo -e "[${BOLD}${RED}✗${RESET}] ${RED}sp not defined => Subdomains inherit p=none: not protected${RESET}"
        elif [[ "$policy" == "quarantine"  ]]; then
            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}sp not defined => Subdomains inherit p=quarantine: partial protection${RESET}"
        elif [[ "$policy" == "reject"  ]]; then
            echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}sp not defined => Subdomains inherit p=reject: strong protection${RESET}"
        else
            echo -e "[${BOLD}${RED}✗${RESET}] ${RED}sp not defined and p= invalid => subdomain policy undefined${RESET}"
        fi
    fi

    # Non-existent subdomain policy (np) – RFC 9989; falls back to sp/p
    if [[ "$dmarc" =~ (^|[[:space:];])np=none ]]; then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}np=none: Non-existent subdomains not protected (RFC 9989)${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])np=quarantine ]]; then
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}np=quarantine: Non-existent subdomains quarantined (RFC 9989)${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])np=reject ]]; then
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}np=reject: Non-existent subdomains rejected (RFC 9989)${RESET}"
    else
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}np not defined: consider np=reject to protect non-existent subdomains (RFC 9989)${RESET}"
    fi

    # DMARC policy test mode (t) – RFC 9989; distinct from the DKIM t= flag.
    # t=y asks receivers to apply the policy one level down (no report impact).
    if [[ "$dmarc" =~ (^|[[:space:];])t=([^;]*) ]]; then
        t_val=$(echo "${BASH_REMATCH[2]}" | tr -d '[:space:]')
        if [[ "$t_val" == "y" ]]; then
            case "$policy" in
                reject)     echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}t=y: policy in test mode – reject applied as quarantine (RFC 9989)${RESET}" ;;
                quarantine) echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}t=y: policy in test mode – quarantine applied as none (RFC 9989)${RESET}" ;;
                *)          echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}t=y: test mode – no effect on p=none (RFC 9989)${RESET}" ;;
            esac
        fi
    fi

    echo

    # Application percentage (pct) – removed in RFC 9989; flag it only if
    # still present (absence is now the norm and needs no message).
    if [[ "$dmarc" =~ (^|[[:space:];])pct=([0-9]+) ]]; then
        pct="${BASH_REMATCH[2]}"
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}pct=$pct: obsolete tag – removed in RFC 9989 (ignored by receivers)${RESET}"
    fi

    # Aggregate reports (rua)
    if [[ "$dmarc" =~ rua=([^;]+) ]]; then
        IFS=',' read -ra rua_list <<< "${BASH_REMATCH[1]}"
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}Aggregate report addresses (rua):${RESET}"
        for addr in "${rua_list[@]}"; do
            echo -e "    - ${addr}"
        done
        dmarc_check_external_destinations "$domain" "rua" "${rua_list[@]}"
    else
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}Missing rua: No aggregate DMARC reports${RESET}"
    fi

    # Aggregate report interval (ri) – removed in RFC 9989
    if [[ "$dmarc" =~ (^|[[:space:];])ri=([0-9]+) ]]; then
        ri="${BASH_REMATCH[2]}"
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}ri=$ri: requested aggregate report interval (~$(( ri / 3600 ))h) – removed in RFC 9989${RESET}"
    fi

    # Forensic reports (ruf)
    if [[ "$dmarc" =~ ruf=([^;]+) ]]; then
        IFS=',' read -ra ruf_list <<< "${BASH_REMATCH[1]}"
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}Forensic report addresses (ruf – may contain sensitive info):${RESET}"
        for addr in "${ruf_list[@]}"; do
            echo -e "    - ${addr}"
        done
        dmarc_check_external_destinations "$domain" "ruf" "${ruf_list[@]}"
    else
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}Missing ruf: No individual failure reports${RESET}"
    fi

    # Failure reporting options (fo) – only relevant when ruf is set
    if [[ "$dmarc" =~ (^|[[:space:];])fo=([^;]+) ]]; then
        fo="${BASH_REMATCH[2]}"
        case "$fo" in
            *1*) echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}fo=$fo: report on any SPF/DKIM failure (needs ruf)${RESET}" ;;
            0)   echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}fo=0: report only if all mechanisms fail (default; needs ruf)${RESET}" ;;
            *)   echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}fo=$fo: failure reporting options (needs ruf)${RESET}" ;;
        esac
    fi

    # Failure report format (rf) – removed in RFC 9989
    if [[ "$dmarc" =~ (^|[[:space:];])rf=([^;]+) ]]; then
        rf="${BASH_REMATCH[2]}"
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}rf=$rf: failure report format (default afrf) – removed in RFC 9989${RESET}"
    fi

    # Alignment DKIM
    if [[ "$dmarc" =~ adkim=s ]]; then
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}adkim=s: Strict DKIM alignment${RESET}"
    elif [[ "$dmarc" =~ adkim=r ]]; then
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}adkim=r: Relaxed DKIM alignment${RESET}"
    else
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}adkim not defined: Default = relaxed (r)${RESET}"
    fi

    # Alignment SPF
    if [[ "$dmarc" =~ aspf=s ]]; then
        echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}aspf=s: Strict SPF alignment${RESET}"
    elif [[ "$dmarc" =~ aspf=r ]]; then
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}aspf=r: Relaxed SPF alignment${RESET}"
    else
        echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}aspf not defined: Default = relaxed (r)${RESET}"
    fi

    # Public Suffix Domain flag (psd) – RFC 9989; default "u" (not a PSD)
    if [[ "$dmarc" =~ (^|[[:space:];])psd=y ]]; then
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}psd=y: record declares a Public Suffix Domain (RFC 9989)${RESET}"
    elif [[ "$dmarc" =~ (^|[[:space:];])psd=n ]]; then
        echo -e "[${BOLD}${YELLOW}i${RESET}] ${YELLOW}psd=n: domain declared as its own organizational domain (RFC 9989)${RESET}"
    fi
}

analyze_dkim() {
    local domain="$1"

    local found=false

    # If user use -s or --selector argument use only this selector if not use defaults
    if [[ ${#SELECTORS[@]} -gt 0 ]]; then
        selectors=("${SELECTORS[@]}")
    else
        selectors=("default" "selector1" "selector2" "google" "mail" "mx" "smtp" "dkim"
                   "mailo" "s1" "s2" "zmail" "k1" "k2" "k3" "mandrill" "amazonses"
                   "cm" "protonmail" "mxvault" "everlytickey1" "everlytickey2"
                   "dkim1024" "dkim2048" "mailjet" "turbo-smtp")
    fi


    echo -e "${BOLD}$SEP${RESET}"
    echo -e "${BOLD}${BLUE}DKIM Analysis:${RESET}"
    echo -e "${BOLD}$SEP${RESET}"

    for selector in "${selectors[@]}"; do
        record=$(dig +short TXT "${selector}._domainkey.${domain}" ${DNS_SERVER:+"$DNS_SERVER"} | sed 's/" "//g' | tr -d '"')

        if [[ -n "$record" ]]; then
            found=true
            echo -e "[${BOLD}${GREEN}✓${RESET}] DKIM record found for selector '${GREEN}${selector}${RESET}'"
            echo -e "${CYAN}$record${RESET}"

            # Extract base64 public key. An empty p= value means the key was
            # revoked (RFC 6376), which differs from a missing p= tag.
            if [[ "$record" =~ (^|[[:space:];])p=([^;]*) ]]; then
                clean_key_b64=$(echo "${BASH_REMATCH[2]}" | tr -d '\r\n[:space:]')

                if [[ -z "$clean_key_b64" ]]; then
                    echo -e "[${BOLD}${RED}✗${RESET}] ${RED}DKIM key revoked: p= present but empty${RESET}"
                # Try decoding and measuring RSA key bits
                elif command -v openssl &>/dev/null && echo "$clean_key_b64" | base64 -d >/dev/null 2>&1; then
                    tmp_der=$(mktemp)
                    echo "$clean_key_b64" | base64 -d > "$tmp_der" 2>/dev/null

                    key_bits=$(openssl pkey -pubin -inform DER -in "$tmp_der" -text -noout 2>/dev/null \
                        | awk -F'[()]' '/Public-Key/ {gsub(/[^0-9]/,"",$2); print $2; exit}')

                    # If RSA parsing fails, detect other key types (ex: ed25519)
                    if [[ -z "$key_bits" ]]; then
                        if grep -q "k=ed25519" <<< "$record"; then
                            echo -e "[${BOLD}${GREEN}i${RESET}] ${GREEN}Key type: Ed25519 - secure${RESET}"
                        else
                            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}Cannot determine key size (non-RSA or parsing issue)${RESET}"
                        fi
                    else
                        # RSA Key length evaluation
                        if (( key_bits < 1024 )); then
                            echo -e "[${BOLD}${RED}✗${RESET}] ${RED}RSA Key: ${key_bits} bits - DANGEROUS, upgrade to 2048+${RESET}"
                        elif (( key_bits < 2048 )); then
                            echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}RSA Key: ${key_bits} bits - weak, upgrade recommended${RESET}"
                        else
                            echo -e "[${BOLD}${GREEN}✓${RESET}] ${GREEN}RSA Key: ${key_bits} bits - OK${RESET}"
                        fi
                    fi
                    rm -f "$tmp_der"

                else
                    echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}Key extraction failed (invalid b64 or missing openssl)${RESET}"
                fi

            else
                echo -e "[${BOLD}${RED}✗${RESET}] ${RED}Invalid DKIM: Missing public key 'p='${RESET}"
            fi

            # Testing flag (t=y): receivers should not enforce DKIM results
            if [[ "$record" =~ (^|[[:space:];])t=([^;]*) ]]; then
                t_flags=$(echo "${BASH_REMATCH[2]}" | tr -d '[:space:]')
                if [[ ":$t_flags:" == *:y:* ]]; then
                    echo -e "[${BOLD}${YELLOW}!!${RESET}] ${YELLOW}t=y: selector in test mode – DKIM results are not enforced${RESET}"
                fi
            fi
            echo
        fi
    done

    if [[ $found == false ]]; then
        echo -e "[${BOLD}${RED}✗${RESET}] ${RED}No DKIM record found${RESET}"
        echo -e "${YELLOW}Selectors tested:${RESET} ${selectors[*]}"
        echo -e "${YELLOW}Either DKIM is not configured or uses a different selector${RESET}"
    fi
}

# Main
MODES=()
DOMAIN=""

# Loop over all arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        --mx) MODES+=("mx")
            shift
            ;;
        --spf)
            MODES+=("spf")
            shift
            ;;
        --dmarc)
            MODES+=("dmarc")
            shift
            ;;
        --dkim)
            MODES+=("dkim")
            shift
            ;;
        -s|--selector)
            if [[ -n "$2" && ! "$2" =~ ^- ]]; then
                SELECTORS+=("$2")
                shift 2
            else
                echo -e "${RED}[✗] Missing selector value for -s/--selector${RESET}"
                exit 1
            fi
            ;;
        --dns)
            if [[ -n "$2" && ! "$2" =~ ^- ]]; then
                DNS_SERVER="@${2}"
                shift 2
            else
                echo -e "${RED}[✗] Missing IP address of custom DNS server for --dns${RESET}"
                exit 1
            fi
            ;;
        -q|--quiet)
            show_header=false
            shift
            ;;
        --no-color)
            shift
            ;;
        *)
            if [[ -z "$DOMAIN" ]]; then
                DOMAIN="$1"
            else
                echo -e "[${BOLD}${RED}✗${RESET}] ${RED} Unknown argument: $1${RESET}"
                show_help
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ ${#MODES[@]} -eq 0 ]]; then
    MODES=("mx" "spf" "dmarc" "dkim")
fi

if [[ -z "$DOMAIN" ]]; then
    show_help
    exit 1
fi

# Check dig
if ! command -v dig &> /dev/null; then
    echo -e "[${BOLD}${RED}✗${RESET}] ${RED} 'dig' command not found. Install dnsutils or equivalent.${RESET}"
    exit 1
fi

if $show_header; then
    echo -e "${BLUE}┏━┓┏━┓┏━╸   ╺┳┓┏┳┓┏━┓┏━┓┏━╸   ┏━╸╻ ╻┏━╸┏━╸╻┏ ┏━╸┏━┓${RESET}"
    echo -e "${BLUE}┗━┓┣━┛┣╸     ┃┃┃┃┃┣━┫┣┳┛┃     ┃  ┣━┫┣╸ ┃  ┣┻┓┣╸ ┣┳┛${RESET}"
    echo -e "${BLUE}┗━┛╹  ╹     ╺┻┛╹ ╹╹ ╹╹┗╸┗━╸   ┗━╸╹ ╹┗━╸┗━╸╹ ╹┗━╸╹┗╸${RESET} v$VERSION"
fi

# Run analysis
for mode in "${MODES[@]}"; do
    case "$mode" in
        mx)     analyze_mx "$DOMAIN" ;;
        spf)    analyze_spf "$DOMAIN" ;;
        dmarc)  analyze_dmarc "$DOMAIN" ;;
        dkim)  analyze_dkim "$DOMAIN" ;;
    esac
done